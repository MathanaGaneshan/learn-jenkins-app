pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                bat 'docker pull node:18-alpine'

                bat '''
                docker run --rm ^
                -v "%cd%":/app ^
                -w /app ^
                node:18-alpine ^
                sh -c "ls -lrt && node --version && npm --version && npm ci && npm run build && ls -lrt"
                '''
            }
        }

        stage('Test') {
            steps {
                bat 'if exist build\\index.html (echo File exists) else (exit 1)'
            }
        }
    }
}
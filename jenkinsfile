pipeline{
    agent any

    stages {
        stage('Build')
        {
            agent{
                docker{
                    image 'node:18-alphine'
                    reuseNode true
                }
            }
            steps {
                bat '''
                ls -lrt
                node --version
                npm --version
                npm ci
                npm run build
                ls -lrt
                '''
            }
        }
    }
}
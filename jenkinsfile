pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                bat '''
                docker pull node:18-alpine

                docker run --rm ^
                -u 0 ^
                -v "%cd%":/app ^
                -w /app ^
                node:18-alpine ^
                sh -c "npm ci && npm run build"
                '''
            }
        }

        stage('Test') {
            steps {
                bat 'if exist build\\index.html (echo Build Success) else (exit 1)'
            }
        }
    }
}